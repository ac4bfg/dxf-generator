TEMPLATE_PATH=templates/ASBUILT_SR.dxf
OUTPUT_PATH=output
HOST=0.0.0.0
PORT=8099
DEBUG=false
API_KEY=

# PDF rendering fonts — directory containing AutoCAD SHX + TTF fonts
# (Arial, ISO, Romans, etc.). Default: fonts/ in project root.
# PDF_FONTS_DIR=fonts

# PDF logo/OLE overlay images (drawing1.png, drawing2.png, ...)
# PDF_LOGO_DIR=logo

# ODA File Converter settings (for DWG conversion)
ODA_PATH=/usr/bin/ODAFileConverter
ODA_ENABLED=true
DEFAULT_OUTPUT_FORMAT=dwg
DWG_VERSION=ACAD2018
