TEMPLATE_PATH=templates/ASBUILT_SR.dxf
OUTPUT_PATH=output
HOST=0.0.0.0
PORT=8099
DEBUG=false
API_KEY=

# ── Concurrency & multi-worker ──────────────────────────────────────────────
# Number of Uvicorn worker processes. Set to number of CPU cores for production.
# Must be 1 when DEBUG=true (reload mode is incompatible with multiple workers).
WORKERS=4

# Max concurrent CPU-heavy ops per worker (DXF/DWG/PDF generation + PDF preview).
# Total system concurrency = WORKERS × MAX_CONCURRENT_HEAVY.
# With WORKERS=4 and MAX_CONCURRENT_HEAVY=1: 4 generates run in parallel,
# each pinned to its own core. Other requests (polling, SVG preview) are
# served immediately regardless of running generates.
MAX_CONCURRENT_HEAVY=1

# Directory for async bulk-job state files (shared across all workers).
# Leave empty to use {OUTPUT_PATH}/jobs (recommended).
# JOBS_PATH=

# Runtime assets — all under assets/ subfolder (not committed to repo).
# Copy from testing/ manually: fonts → assets/fonts, logo → assets/logo,
# thumbnails → assets/thumbnails
# PDF_FONTS_DIR=assets/fonts
# PDF_LOGO_DIR=assets/logo
# THUMBNAILS_PATH=assets/thumbnails

# ODA File Converter settings (for DWG conversion)
ODA_PATH=/usr/bin/ODAFileConverter
ODA_ENABLED=true
DEFAULT_OUTPUT_FORMAT=dwg
DWG_VERSION=ACAD2018
