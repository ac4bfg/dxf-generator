{
  "info": {
    "name": "DXF Isometric Engine API",
    "description": "Test collection untuk endpoint /api/isometric (dynamic isometric drawing engine).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url", "value": "http://localhost:8099", "type": "string"},
    {"key": "api_key", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "Health Check (legacy)",
      "request": {
        "method": "GET",
        "url": {"raw": "{{base_url}}/api/dxf/health", "host": ["{{base_url}}"], "path": ["api", "dxf", "health"]}
      }
    },
    {
      "name": "List Blocks",
      "request": {
        "method": "GET",
        "header": [{"key": "x-api-key", "value": "{{api_key}}", "type": "text"}],
        "url": {"raw": "{{base_url}}/api/isometric/blocks", "host": ["{{base_url}}"], "path": ["api", "isometric", "blocks"]}
      }
    },
    {
      "name": "Get Variants Info",
      "request": {
        "method": "GET",
        "header": [{"key": "x-api-key", "value": "{{api_key}}", "type": "text"}],
        "url": {"raw": "{{base_url}}/api/isometric/variants", "host": ["{{base_url}}"], "path": ["api", "isometric", "variants"]}
      }
    },
    {
      "name": "Get Block Thumbnail",
      "request": {
        "method": "GET",
        "header": [{"key": "x-api-key", "value": "{{api_key}}", "type": "text"}],
        "url": {
          "raw": "{{base_url}}/api/isometric/thumbnail/klem_3-4",
          "host": ["{{base_url}}"],
          "path": ["api", "isometric", "thumbnail", "klem_3-4"]
        }
      }
    },
    {
      "name": "Generate - Simple (2 pipes)",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "x-api-key", "value": "{{api_key}}", "type": "text"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"start_block\": \"start-BR\",\n  \"file_name\": \"simple_test\",\n  \"segments\": [\n    {\"type\": \"pipe\", \"direction\": \"forward\", \"length_mm\": 5000, \"dimension\": true},\n    {\"type\": \"pipe\", \"direction\": \"up\", \"length_mm\": 3000, \"dimension\": true}\n  ]\n}"
        },
        "url": {"raw": "{{base_url}}/api/isometric/generate", "host": ["{{base_url}}"], "path": ["api", "isometric", "generate"]}
      }
    },
    {
      "name": "Generate - Full BR (canonical SR)",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "x-api-key", "value": "{{api_key}}", "type": "text"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"start_block\": \"start-BR\",\n  \"start_insert\": [209.52, 124.98],\n  \"file_name\": \"test_BR\",\n  \"segments\": [\n    {\"type\": \"pipe\", \"direction\": \"forward\", \"length_mm\": 5000, \"dimension\": true},\n    {\"type\": \"pipe\", \"direction\": \"up\", \"length_mm\": 500},\n    {\"type\": \"component\", \"block\": \"klem_3-4\", \"color\": 5, \"gap\": 3.07},\n    {\"type\": \"pipe\", \"direction\": \"up\", \"length_mm\": 2000},\n    {\"type\": \"component\", \"block\": \"ball_valve_3-4\", \"color\": 5, \"gap\": 4.0},\n    {\"type\": \"pipe\", \"direction\": \"up\", \"length_mm\": 500},\n    {\"type\": \"pipe\", \"direction\": \"right\", \"length_mm\": 250,\n     \"direction_by_variant\": {\"start-TR\": \"left\"},\n     \"bend_side_by_variant\": {\"start-BL\": \"right\"}},\n    {\"type\": \"component\", \"block\": \"REGULATOR-2\", \"gap\": 0,\n     \"bend_side_by_variant\": {\"start-BL\": \"right\"},\n     \"scale_by_variant\": {\"start-TL\": [1, 1]}},\n    {\"type\": \"pipe\", \"direction\": \"down\", \"length_mm\": 200},\n    {\"type\": \"component\", \"block\": \"meteran\", \"gap\": 0, \"scale\": [10, 10],\n     \"block_by_variant\": {\"start-BL\": \"meteran-BL\"},\n     \"scale_by_variant\": {\"start-BL\": [1, 1], \"start-TL\": [10, 10]}}\n  ],\n  \"combined_dims\": [{\"from_seg\": 1, \"to_seg\": 5}],\n  \"output_format\": \"dxf\"\n}"
        },
        "url": {"raw": "{{base_url}}/api/isometric/generate", "host": ["{{base_url}}"], "path": ["api", "isometric", "generate"]}
      }
    },
    {
      "name": "Generate - Variant BL",
      "request": {
        "method": "POST",
