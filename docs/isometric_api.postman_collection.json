      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "x-api-key", "value": "{{api_key}}", "type": "text"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"start_block\": \"start-BR\",\n  \"file_name\": \"test_dwg_output\",\n  \"output_format\": \"dwg\",\n  \"segments\": [\n    {\"type\": \"pipe\", \"direction\": \"forward\", \"length_mm\": 5000, \"dimension\": true},\n    {\"type\": \"pipe\", \"direction\": \"up\", \"length_mm\": 3000, \"dimension\": true}\n  ]\n}"
